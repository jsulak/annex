#!/usr/bin/env bash
set -euo pipefail

export DIGITALOCEAN_TOKEN="dop_v1_..."
export SESSION_SECRET="change-me-generate-with-openssl-rand-hex-32"

# SSH key name in DigitalOcean (also used as ~/.ssh/<name> for the private key)
export TF_VAR_ssh_key_name="your-ssh-key-name"

# Domain name for HTTPS (leave empty to serve on bare IP over HTTP)
export DOMAIN=""

# ── Usage ─────────────────────────────────────────────────
# First-time setup (new droplet):
#   ./deploy.sh init
#
# Re-provision existing droplet (e.g. update Caddy config):
#   ./deploy.sh provision
#
# Deploy the app (full — includes npm ci, PM2 config):
#   ./deploy.sh deploy
#
# Quick push (code-only — build, rsync, restart):
#   ./deploy.sh push
#
# Set/reset the login password:
#   ./deploy.sh setup
#
# Full teardown and rebuild:
#   ./deploy.sh destroy
#   ./deploy.sh init

case "${1:-}" in
  init)
    make infra-init
    make infra-apply
    make wait-for-ssh
    FIRST_RUN=1 make provision
    make deploy
    make setup
    ;;
  provision)
    make provision
    ;;
  deploy)
    make deploy
    ;;
  push)
    make push
    ;;
  destroy)
    make infra-destroy
    ;;
  setup)
    make setup
    ;;
  *)
    echo "Usage: $0 {init|provision|deploy|push|setup|destroy}"
    exit 1
    ;;
esac
